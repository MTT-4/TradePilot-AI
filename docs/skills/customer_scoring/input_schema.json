{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "customer_scoring.input",
  "type": "object",
  "required": ["inquiry"],
  "properties": {
    "inquiry": { "type": "object", "description": "inquiry_detection.output" },
    "company_email": { "type": "string" },
    "website": { "type": "string" },
    "country": { "type": "string" },
    "quantity": { "type": "string" },
    "request_clarity": { "type": "string", "enum": ["low", "medium", "high"] }
  },
  "additionalProperties": false
}
