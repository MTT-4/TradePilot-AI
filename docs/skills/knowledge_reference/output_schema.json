{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "knowledge_reference.output",
  "type": "object",
  "required": ["matched_knowledge", "missing_information", "confidence"],
  "properties": {
    "matched_knowledge": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "content", "source_file", "source_type", "confidence"],
        "properties": {
          "title": { "type": "string" },
          "content": { "type": "string" },
          "source_file": { "type": "string" },
          "source_type": {
            "type": "string",
            "enum": ["pdf", "docx", "xlsx", "image", "manual", "url", "mock"]
          },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] }
        }
      }
    },
    "missing_information": { "type": "array", "items": { "type": "string" } },
    "source_files": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "notes_for_sales": { "type": "string" }
  },
  "additionalProperties": false
}
