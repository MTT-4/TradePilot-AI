{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "order_delivery_communication.input",
  "type": "object",
  "required": ["stage"],
  "properties": {
    "stage": {
      "type": "string",
      "enum": ["pi", "payment_reminder", "production_update", "inspection", "shipment", "after_sales", "restock"]
    },
    "leadId": { "type": "string" },
    "inquiryId": { "type": "string" },
    "facts": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "人工提供的占位值，如 order_no/amount/carrier/tracking_no 等；未提供的字段渲染为 [待确认]"
    }
  },
  "additionalProperties": false
}
