{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "quotation_assistant.output",
  "type": "object",
  "required": ["currency", "incoterm", "needs_base_cost", "requires_human_confirmation", "draft_text"],
  "properties": {
    "product": { "type": "string" },
    "quantity": { "type": "string" },
    "currency": { "type": "string" },
    "incoterm": { "type": "string", "enum": ["FOB", "CIF", "EXW"] },
    "moq": { "type": ["integer", "null"] },
    "unitPrice": { "type": ["number", "null"], "description": "null 表示待人工填写" },
    "tiers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "minQty": { "type": "integer" },
          "discountPercent": { "type": "number" },
          "unitPrice": { "type": ["number", "null"] }
        }
      }
    },
    "validUntil": { "type": "string" },
    "paymentTerms": { "type": "string" },
    "needs_base_cost": { "type": "boolean" },
    "requires_human_confirmation": { "const": true },
    "confirmation_checklist": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "draft_text": { "type": "string" }
  },
  "additionalProperties": false
}
