{
  "name": "tradepilot-ai-local-server",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "dotenv -e .env -- npm --workspace @tradepilot/web run dev",
    "worker:jobs": "dotenv -e .env -- npm --workspace @tradepilot/web run worker:jobs",
    "build": "dotenv -e .env -- npm --workspace @tradepilot/web run build",
    "start": "dotenv -e .env -- npm --workspace @tradepilot/web run start",
    "lint": "turbo run lint --filter=@tradepilot/web",
    "typecheck": "turbo run typecheck --filter=@tradepilot/web",
    "test": "turbo run test --filter=@tradepilot/web",
    "test:redline": "dotenv -e .env -- npm --workspace @tradepilot/web run test -- --run server/db/tenant-prisma.test.ts server/model-gateway/t0.5-model-gateway.test.ts server/tracking/t0.6-tracking.test.ts server/sites/t2.1-sites.test.ts server/leads/t4.1-public-leads.test.ts server/inbound-email/t4.2-inbound-email.test.ts server/replies/t5.1-replies-dashboard.test.ts",
    "test:closed-loop": "dotenv -e .env -- npm --workspace @tradepilot/web run test -- --run server/acceptance/t6.4-closed-loop.test.ts",
    "test:hardening": "dotenv -e .env -- npm --workspace @tradepilot/web run test -- --run server/data-requests/t7.2-data-requests.test.ts",
    "check": "turbo run lint typecheck test --filter=@tradepilot/web",
    "format": "prettier --write .",
    "prisma:generate": "dotenv -e .env -- prisma generate",
    "prisma:migrate": "dotenv -e .env -- prisma migrate dev",
    "prisma:seed": "dotenv -e .env -- prisma db seed",
    "prisma:assert-tenant": "node tools/check/assert-tenant-fields.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.4",
    "prettier": "^3.6.2",
    "prisma": "^6.9.0",
    "tsx": "^4.20.6",
    "turbo": "^2.5.8"
  }
}
